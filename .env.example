# Ρυθμίσεις για το production deployment (docker-compose.prod.yml).
# Αντίγραψε σε .env και άλλαξε τις τιμές.

# Υποχρεωτικό: μυστικό υπογραφής των JWT - βάλε ένα μεγάλο τυχαίο string
JWT_SECRET=

# Προαιρετικά (έχουν defaults)
JWT_EXPIRES_IN=2h
DB_PASSWORD=petgroom
DB_ROOT_PASSWORD=root
APP_PORT=8085
